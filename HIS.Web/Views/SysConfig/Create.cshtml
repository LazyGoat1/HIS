@model HIS.Models.Entities.SysConfig
@{ Layout = "_LayoutPopup"; ViewData["Title"] = Model.Id > 0 ? "编辑配置" : "新增配置"; }
<form class="layui-form" lay-filter="form" style="padding:20px 30px 0 10px;">
    <input type="hidden" name="Id" value="@Model.Id" />
    <div class="layui-form-item">
        <label class="layui-form-label required">配置键</label>
        <div class="layui-input-block"><input type="text" name="ConfigKey" lay-verify="required" class="layui-input" value="@Model.ConfigKey" /></div>
    </div>
    <div class="layui-form-item">
        <label class="layui-form-label required">配置值</label>
        <div class="layui-input-block"><input type="text" name="ConfigValue" lay-verify="required" class="layui-input" value="@Model.ConfigValue" /></div>
    </div>
    <div class="layui-form-item">
        <label class="layui-form-label">说明</label>
        <div class="layui-input-block"><input type="text" name="Description" class="layui-input" value="@Model.Description" /></div>
    </div>
    <div class="layui-form-item" style="text-align:center;margin-top:15px;">
        <button type="button" class="layui-btn" lay-submit lay-filter="submitForm">提交</button>
        <button type="button" class="layui-btn layui-btn-primary" onclick="var i=parent.layer.getFrameIndex(window.name);parent.layer.close(i);">取消</button>
    </div>
</form>
@section Scripts {
<script>
    layui.use('form', function () { var form = layui.form;
        form.on('submit(submitForm)', function (data) {
            var f = data.field;
            var url = (parseInt(f.Id)||0) > 0 ? '/SysConfig/Edit' : '/SysConfig/Create';
            http.post(url, { Id: parseInt(f.Id)||0, ConfigKey: f.ConfigKey, ConfigValue: f.ConfigValue, Description: f.Description||null }).then(function (res) {
                handleResponse(res, null, function () { parent.location.reload(); });
            });
            return false;
        });
    });
</script>
}
