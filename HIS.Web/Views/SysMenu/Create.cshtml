@model HIS.Models.DTOs.SysMenuDto
@{
    Layout = "_LayoutPopup";
}

<form class="layui-form" lay-filter="menuForm" style="padding:20px 30px 0 10px;">
    <input type="hidden" name="Id" value="@Model.Id" />
    <input type="hidden" name="ParentId" value="@Model.ParentId" />

    <div class="layui-form-item">
        <label class="layui-form-label required">菜单名称</label>
        <div class="layui-input-block">
            <input type="text" name="MenuName" lay-verify="required" class="layui-input" value="@Model.MenuName" />
        </div>
    </div>
    <div class="layui-form-item">
        <label class="layui-form-label required">菜单类型</label>
        <div class="layui-input-block">
            <select name="MenuType" lay-verify="required">
                @foreach (var item in ViewBag.MenuTypes)
                {
                    <option value="@item.Value" selected="@(item.Value == Model.MenuType)">@item.Name</option>
                }
            </select>
        </div>
    </div>
    <div class="layui-form-item">
        <label class="layui-form-label">菜单URL</label>
        <div class="layui-input-block">
            <input type="text" name="MenuUrl" class="layui-input" value="@Model.MenuUrl" placeholder="/System/SysRole/Index" />
        </div>
    </div>
    <div class="layui-form-item">
        <label class="layui-form-label">图标</label>
        <div class="layui-input-block">
            <input type="text" name="MenuIcon" class="layui-input" value="@Model.MenuIcon" placeholder="layui-icon-xxxx" />
        </div>
    </div>
    <div class="layui-form-item">
        <label class="layui-form-label">权限标识</label>
        <div class="layui-input-block">
            <input type="text" name="PermissionCode" class="layui-input" value="@Model.PermissionCode" placeholder="如: sys:user:add" />
        </div>
    </div>
    <div class="layui-form-item">
        <label class="layui-form-label">排序</label>
        <div class="layui-input-block">
            <input type="number" name="SortOrder" class="layui-input" value="@Model.SortOrder" />
        </div>
    </div>
    <div class="layui-form-item">
        <label class="layui-form-label">状态</label>
        <div class="layui-input-block">
            <input type="checkbox" name="Status" value="1" lay-skin="switch" lay-text="启用|禁用" @(Model.Status == 1 ? "checked" : "") />
        </div>
    </div>
    <div class="layui-form-item" style="text-align:center;">
        <button type="button" class="layui-btn" lay-submit lay-filter="submitForm">提交保存</button>
    </div>
</form>

@section Scripts {
<script>
    layui.use('form', function () {
        var form = layui.form;
        form.on('submit(submitForm)', function (data) {
            var f = data.field;
            var url = (parseInt(f.Id) || 0) > 0 ? '/SysMenu/Edit' : '/SysMenu/Create';
            http.post(url, {
                Id: parseInt(f.Id) || 0,
                ParentId: parseInt(f.ParentId) || null,
                MenuName: f.MenuName,
                MenuType: parseInt(f.MenuType) || 2,
                MenuUrl: f.MenuUrl || null,
                MenuIcon: f.MenuIcon || null,
                SortOrder: parseInt(f.SortOrder) || 1,
                PermissionCode: f.PermissionCode || null,
                Status: parseInt(f.Status) || 1
            }).then(function (res) {
                handleResponse(res, null, function () { parent.location.reload(); });
            });
            return false;
        });
    });
</script>
}
